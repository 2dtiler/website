---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { docsGuides, getDocsGuidePath } from '../data/docsGuides';

const workflowGuides = docsGuides.filter((guide) => guide.category !== 'Reference');
const referenceGuides = docsGuides.filter((guide) => guide.category === 'Reference');
const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebPage',
		name: '2D Tiler Docs',
		description:
			'Documentation, tutorials, and workflow guides for 2D Tiler, a free open-source editor for maps, tilesets, pixel assets, palettes, AI asset drafts, and engine exports.',
		url: 'https://2dtiler.com/docs',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'ItemList',
		name: '2D Tiler documentation guides',
		itemListElement: docsGuides.map((guide, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			name: guide.title,
			url: `https://2dtiler.com${getDocsGuidePath(guide.slug)}`,
		})),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: [
			{
				'@type': 'Question',
				name: 'What is 2D Tiler used for?',
				acceptedAnswer: {
					'@type': 'Answer',
					text: '2D Tiler is used to build layered 2D game maps, manage tilesets, edit pixel assets and palettes, create AI-assisted asset drafts, and export map or tileset data for game engines and custom pipelines.',
				},
			},
			{
				'@type': 'Question',
				name: 'Is 2D Tiler free and open source?',
				acceptedAnswer: {
					'@type': 'Answer',
					text: 'Yes. 2D Tiler is free to use and open source under the MIT license.',
				},
			},
			{
				'@type': 'Question',
				name: 'Which engines and tools can 2D Tiler export to?',
				acceptedAnswer: {
					'@type': 'Answer',
					text: '2D Tiler includes export paths for native files, raster images, Phaser bundles, Tiled maps and tilesets, Godot scenes, Unity bundles, GameMaker rooms, Defold resources, tIDE maps, and Mappy FMP maps.',
				},
			},
			{
				'@type': 'Question',
				name: 'Does 2D Tiler include pixel art and palette tools?',
				acceptedAnswer: {
					'@type': 'Answer',
					text: 'Yes. The built-in image editor supports pixel drawing and editing tools, while palette import covers formats such as GIMP GPL, Adobe ASE, Aseprite, JASC PAL, Paint.NET TXT, and HEX lists.',
				},
			},
		],
	},
];
---

<Layout
	title="2D Tiler Docs, Tutorials, and Workflow Guides | 2D Tiler"
	description="Learn how to build maps, import tilesets, use autotile terrain tools, edit pixel assets, import palettes, generate AI asset drafts, and export game-ready data with 2D Tiler."
	structuredData={structuredData}
>
	<Nav />
	<main class="mx-auto flex min-h-[calc(100vh-17rem)] w-full max-w-7xl flex-col gap-14 px-6 py-24 lg:px-8">
		<section class="reveal grid gap-8 lg:grid-cols-[minmax(0,1fr)_340px] lg:items-end">
			<div class="flex max-w-4xl flex-col gap-4">
				<p class="font-label-mono text-xs uppercase tracking-[0.28em] text-secondary">Docs / Workflows / Reference</p>
				<h1 class="text-4xl font-semibold uppercase text-primary md:text-6xl">Learn the full 2D Tiler workflow.</h1>
				<p class="max-w-3xl text-lg leading-8 text-on-surface-variant">
					Use these guides to create projects, paint maps, manage tilesets and terrain rules, edit pixel assets, import palettes, generate AI asset drafts, and export files for game engines.
				</p>
			</div>

			<aside class="flex flex-col gap-4 border border-outline/35 bg-surface-container-low/70 p-6 backdrop-blur-2xl">
				<p class="font-label-mono text-xs uppercase tracking-[0.24em] text-secondary">Fast paths</p>
				<a class="inline-flex items-center justify-between border border-outline/30 px-4 py-3 text-sm uppercase tracking-[0.18em] text-primary transition-colors duration-200 hover:border-outline hover:bg-surface-container" href="https://app.2dtiler.com/">
					<span>Open the editor</span>
					<span class="material-symbols-outlined text-base">arrow_forward</span>
				</a>
				<a class="inline-flex items-center justify-between border border-outline/30 px-4 py-3 text-sm uppercase tracking-[0.18em] text-primary transition-colors duration-200 hover:border-outline hover:bg-surface-container" href={getDocsGuidePath('getting-started')}>
					<span>Create first project</span>
					<span class="material-symbols-outlined text-base">arrow_forward</span>
				</a>
				<a class="inline-flex items-center justify-between border border-outline/30 px-4 py-3 text-sm uppercase tracking-[0.18em] text-primary transition-colors duration-200 hover:border-outline hover:bg-surface-container" href={getDocsGuidePath('import-export')}>
					<span>Export to engines</span>
					<span class="material-symbols-outlined text-base">arrow_forward</span>
				</a>
			</aside>
		</section>

		<section class="grid gap-6" id="workflow-guides" aria-labelledby="workflow-guides-heading">
			<div class="reveal flex max-w-3xl flex-col gap-3">
				<p class="font-label-mono text-xs uppercase tracking-[0.24em] text-secondary">Core guides</p>
				<h2 id="workflow-guides-heading" class="text-3xl font-medium text-primary">Build from first map to final export</h2>
				<p class="text-base leading-7 text-on-surface-variant">Follow these guides in order for a complete production pass, or jump directly to the tool you need.</p>
			</div>
			<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
				{workflowGuides.map((guide, index) => (
					<a class={`reveal reveal-delay-${(index % 4) + 1} group flex flex-col gap-4 border border-outline/35 bg-surface-container-low/70 p-7 backdrop-blur-2xl transition-colors duration-200 hover:border-outline/80`} href={getDocsGuidePath(guide.slug)}>
						<div class="flex items-center justify-between gap-4">
							<span class="material-symbols-outlined text-[32px] text-secondary">{guide.icon}</span>
							<span class="material-symbols-outlined text-lg text-on-surface-variant transition-colors duration-200 group-hover:text-primary">arrow_forward</span>
						</div>
						<div>
							<p class="font-label-mono text-xs uppercase tracking-[0.22em] text-secondary">{guide.category}</p>
							<h3 class="mt-3 text-2xl font-medium text-primary group-hover:text-secondary">{guide.title}</h3>
							<p class="mt-4 text-base leading-7 text-on-surface-variant">{guide.summary}</p>
						</div>
					</a>
				))}
			</div>
		</section>

		<section class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_360px]" id="workflow-path">
			<article class="reveal border border-outline/35 bg-surface-container-low/70 p-8 backdrop-blur-2xl md:p-10">
				<p class="font-label-mono text-xs uppercase tracking-[0.24em] text-secondary">Workflow path</p>
				<h2 class="mt-3 text-3xl font-medium text-primary">A practical way to learn the editor</h2>
				<div class="mt-8 grid gap-6 md:grid-cols-2">
					<div class="flex flex-col gap-3">
						<h3 class="text-xl font-medium text-primary">1. Create the project</h3>
						<p class="text-base leading-7 text-on-surface-variant">Start with a native project, choose a grid, and add the first map and tileset.</p>
					</div>
					<div class="flex flex-col gap-3">
						<h3 class="text-xl font-medium text-primary">2. Build the map</h3>
						<p class="text-base leading-7 text-on-surface-variant">Paint layers, place object metadata, configure terrain rules, and use shortcuts while iterating.</p>
					</div>
					<div class="flex flex-col gap-3">
						<h3 class="text-xl font-medium text-primary">3. Refine assets</h3>
						<p class="text-base leading-7 text-on-surface-variant">Adjust pixel art, import palettes, and explore AI-generated drafts for missing asset ideas.</p>
					</div>
					<div class="flex flex-col gap-3">
						<h3 class="text-xl font-medium text-primary">4. Export the pipeline</h3>
						<p class="text-base leading-7 text-on-surface-variant">Save native backups, export the active map or tileset, and review the result in your target engine.</p>
					</div>
				</div>
			</article>

			<aside class="reveal reveal-delay-1 flex h-max flex-col gap-4 border border-outline/35 bg-surface-container-low/70 p-6 backdrop-blur-2xl">
				<p class="font-label-mono text-xs uppercase tracking-[0.24em] text-secondary">Reference guides</p>
				{referenceGuides.map((guide) => (
					<a class="group border border-outline/30 p-4 transition-colors duration-200 hover:border-outline hover:bg-surface-container" href={getDocsGuidePath(guide.slug)}>
						<div class="flex items-center justify-between gap-3">
							<span class="material-symbols-outlined text-[26px] text-secondary">{guide.icon}</span>
							<span class="material-symbols-outlined text-base text-on-surface-variant group-hover:text-primary">arrow_forward</span>
						</div>
						<h3 class="mt-3 text-lg font-medium text-primary group-hover:text-secondary">{guide.title}</h3>
						<p class="mt-2 text-sm leading-6 text-on-surface-variant">{guide.summary}</p>
					</a>
				))}
			</aside>
		</section>

		<section class="reveal border border-outline/35 bg-surface-container-low/70 p-8 backdrop-blur-2xl md:p-10" id="faq">
			<p class="font-label-mono text-xs uppercase tracking-[0.24em] text-secondary">FAQ</p>
			<h2 class="mt-3 text-3xl font-medium text-primary">Common questions from game developers</h2>
			<div class="mt-8 grid gap-6 md:grid-cols-2">
				<article class="flex flex-col gap-3">
					<h3 class="text-xl font-medium text-primary">What is 2D Tiler built for?</h3>
					<p class="text-base leading-7 text-on-surface-variant">2D Tiler is built for creating layered maps, managing tilesets, editing pixel assets and palettes, generating asset drafts, and exporting production files for 2D games.</p>
				</article>
				<article class="flex flex-col gap-3">
					<h3 class="text-xl font-medium text-primary">Is it free and open source?</h3>
					<p class="text-base leading-7 text-on-surface-variant">Yes. The editor is free to use and open source under the MIT license.</p>
				</article>
				<article class="flex flex-col gap-3">
					<h3 class="text-xl font-medium text-primary">Can I export to Godot, Unity, or Tiled?</h3>
					<p class="text-base leading-7 text-on-surface-variant">Yes. 2D Tiler includes engine and tool exports for Godot, Unity, Tiled, GameMaker, Defold, Phaser, tIDE, Mappy, raster images, and native files.</p>
				</article>
				<article class="flex flex-col gap-3">
					<h3 class="text-xl font-medium text-primary">Does it replace every art tool?</h3>
					<p class="text-base leading-7 text-on-surface-variant">It is meant to cover common day-to-day map, tileset, palette, image-editing, and export work. Specialized art pipelines can still use external tools alongside native imports and exports.</p>
				</article>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
