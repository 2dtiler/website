---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ReleaseNotesArchive from '../../components/ReleaseNotesArchive.astro';
import { getReleaseNotesPage, getReleaseNotesPageCount } from '../../data/releaseNotes';

const currentPage = 1;
const totalPages = await getReleaseNotesPageCount();
const notes = await getReleaseNotesPage(currentPage);
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: '2D Tiler Release Notes',
	description:
		'Browse the 2D Tiler changelog, release notes, and map editor updates covering tilesets, collision workflows, and export improvements.',
	url: 'https://2dtiler.com/blog',
};
---

<Layout
	title="2D Tile Map Editor Release Notes and Changelog | 2D Tiler"
	description="Browse the 2D Tiler changelog, release notes, and map editor updates covering tilesets, collision workflows, and export improvements."
	structuredData={structuredData}
>
	<Nav />
	<main class="min-h-screen">
		<ReleaseNotesArchive notes={notes} currentPage={currentPage} totalPages={totalPages} />
	</main>
	<Footer />
</Layout>
