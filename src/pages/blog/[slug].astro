---
import { render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import {
	formatReleaseDate,
	getAllReleaseNoteEntries,
	type ReleaseNoteEntry,
} from '../../data/releaseNotes';

export async function getStaticPaths() {
	const entries = await getAllReleaseNoteEntries();

	return entries.map((entry: ReleaseNoteEntry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

interface Props {
	entry: ReleaseNoteEntry;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const note = entry.data;
---

<Layout title={`${note.version} — ${note.title} — 2D Tiler`} description={note.summary}>
	<Nav />
	<main class="post-shell">
		<div class="site-shell">
			<header class="post-head reveal">
				<p class="eyebrow">Release note / {note.version}</p>
				<h1 class="post-title">{note.title}</h1>
				<p class="section-copy post-summary">{note.summary}</p>
			</header>

			<div class="post-layout">
				<article class="post-body-card reveal reveal-delay-1">
					<div class="post-meta-row">
						<span class="meta-label">Published</span>
						<span class="muted-note">Release archive</span>
						<span class="meta-value">{formatReleaseDate(note.publishedAt)}</span>
					</div>
					<div class="post-meta-row">
						<span class="meta-label">Status</span>
						<span class="muted-note">Current note state</span>
						<span class="meta-value">{note.status}</span>
					</div>
					<div class="post-meta-row">
						<span class="meta-label">Read time</span>
						<span class="muted-note">Scan or full read</span>
						<span class="meta-value">{note.readTime}</span>
					</div>
					<div class="note-divider"></div>
					<div class="post-prose release-markdown">
						<Content />
					</div>
				</article>

				<aside class="blog-intro-card article-sidebar reveal reveal-delay-2">
					<p class="eyebrow">Release source / metadata</p>
					<div class="post-meta-row">
						<span class="meta-label">Version</span>
						<span class="muted-note">Git tag</span>
						<span class="meta-value">{note.version}</span>
					</div>
					<div class="post-meta-row">
						<span class="meta-label">Source</span>
						<span class="muted-note">GitHub release</span>
						<a class="post-link" href={note.sourceUrl} target="_blank" rel="noreferrer">Open on GitHub</a>
					</div>
					<a class="post-link" href="/blog">Back to release archive</a>
				</aside>
			</div>
		</div>
	</main>
	<Footer />
</Layout>
