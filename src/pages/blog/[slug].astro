---
import { render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import {
	getAllReleaseNoteEntries,
	formatReleaseDate, type ReleaseNoteEntry,
} from '../../data/releaseNotes';

export async function getStaticPaths() {
	const entries = await getAllReleaseNoteEntries();

	return entries.map((entry: ReleaseNoteEntry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

interface Props {
	entry: ReleaseNoteEntry;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const note = entry.data;
const canonicalUrl = `https://2dtiler.com/blog/${entry.id}`;
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: `${note.version} — ${note.title}`,
	description: note.summary,
	datePublished: note.publishedAt.toISOString(),
	mainEntityOfPage: canonicalUrl,
	url: canonicalUrl,
	image: 'https://2dtiler.com/screenshot.png',
	author: {
		'@type': 'Organization',
		name: '2D Tiler',
	},
	publisher: {
		'@type': 'Organization',
		name: '2D Tiler',
	},
};
---

<Layout
	title={`${note.version} — ${note.title} — 2D Tiler Release Notes`}
	description={note.summary}
	ogType="article"
	canonicalUrl={canonicalUrl}
	structuredData={structuredData}
>
	<Nav />
	<main class="mx-auto w-full max-w-7xl px-6 py-20 lg:px-8">
		<header class="reveal flex max-w-4xl flex-col gap-4">
			<p class="font-label-mono text-xs uppercase tracking-[0.28em] text-secondary">Release note / {note.version}</p>
			<h1 class="text-4xl font-semibold uppercase tracking-[-0.04em] text-primary md:text-6xl">{note.title}</h1>
			<p class="max-w-3xl text-lg leading-8 text-on-surface-variant">{note.summary}</p>
		</header>

		<div class="mt-12 grid gap-6 xl:grid-cols-[minmax(0,1fr)_320px]">
			<article class="reveal reveal-delay-1 rounded-2xl border border-outline/35 bg-surface-container-low/70 p-6 backdrop-blur-2xl md:p-8">
				<div class="grid gap-4 border-b border-outline/20 pb-6 md:grid-cols-3">
					<div class="flex flex-col gap-1">
						<span class="font-label-mono text-[11px] uppercase tracking-[0.22em] text-on-surface-variant">Published</span>
						<span class="text-sm text-primary">{formatReleaseDate(note.publishedAt)}</span>
					</div>
					<div class="flex flex-col gap-1">
						<span class="font-label-mono text-[11px] uppercase tracking-[0.22em] text-on-surface-variant">Status</span>
						<span class="text-sm text-primary">{note.status}</span>
					</div>
					<div class="flex flex-col gap-1">
						<span class="font-label-mono text-[11px] uppercase tracking-[0.22em] text-on-surface-variant">Read time</span>
						<span class="text-sm text-primary">{note.readTime}</span>
					</div>
				</div>
				<div class="post-prose release-markdown mt-8">
					<Content />
				</div>
			</article>

			<aside class="reveal reveal-delay-2 flex h-max flex-col gap-4 rounded-2xl border border-outline/35 bg-surface-container-low/70 p-6 backdrop-blur-2xl">
				<p class="font-label-mono text-xs uppercase tracking-[0.24em] text-secondary">Release source / metadata</p>
				<div class="flex flex-col gap-1 border-b border-outline/20 pb-4">
					<span class="font-label-mono text-[11px] uppercase tracking-[0.22em] text-on-surface-variant">Version</span>
					<span class="text-sm text-primary">{note.version}</span>
				</div>
				<div class="flex flex-col gap-2 border-b border-outline/20 pb-4">
					<span class="font-label-mono text-[11px] uppercase tracking-[0.22em] text-on-surface-variant">Source</span>
					<a class="text-sm uppercase tracking-[0.18em] text-primary underline decoration-outline underline-offset-4 transition-colors duration-200 hover:text-secondary" href={note.sourceUrl} target="_blank" rel="noreferrer">
						Open on GitHub
					</a>
				</div>
				<a class="inline-flex w-max items-center justify-center border border-outline px-4 py-2 font-body text-xs font-medium uppercase tracking-[0.24em] text-primary transition-colors duration-200 hover:bg-primary hover:text-surface" href="/blog">
					Back to Release Archive
				</a>
			</aside>
		</div>
	</main>
	<Footer />
</Layout>
