---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import WorkflowShowcase from '../components/WorkflowShowcase.astro';
import EditorPreview from '../components/EditorPreview.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'SoftwareApplication',
		name: '2D Tiler',
		applicationCategory: 'DeveloperApplication',
		operatingSystem: 'Web',
		description:
			'Free, open-source 2D tile map editor for indie game developers building maps, tilesets, pixel assets, palettes, AI asset drafts, and engine-ready exports.',
		url: 'https://2dtiler.com/',
		image: 'https://2dtiler.com/screenshot.png',
		offers: {
			'@type': 'Offer',
			price: '0',
			priceCurrency: 'USD',
		},
		featureList: [
			'Layered 2D map editing',
			'Tileset and autotile terrain workflows',
			'Pixel asset and palette editing',
			'AI-assisted asset draft generation',
			'Native project, map, and tileset files',
			'Export workflows for Godot, Unity, Tiled, GameMaker, Defold, Phaser, tIDE, and Mappy',
		],
		sameAs: ['https://github.com/2dtiler', 'https://app.2dtiler.com/'],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: '2D Tiler',
		url: 'https://2dtiler.com/',
		description:
			'2D Tiler is a free, open-source 2D tile map editor for indie game developers who need faster level design, tileset workflow, and export control.',
	},
];
---


<Layout
	title="Free Open-Source 2D Tile Map Editor for Indie Game Developers | 2D Tiler"
	description="Build maps, tilesets, pixel assets, palettes, AI drafts, and engine-ready exports in a free, open-source browser editor for 2D game development."
	structuredData={structuredData}
>
	<Nav />
	<main>
	<Hero />
	<Features />
	<WorkflowShowcase />
	<EditorPreview />
	<FinalCta />
	</main>
	<Footer />
</Layout>
