---
const highlights = [
	{
		icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2L3 7V17L12 22L21 17V7L12 2Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M12 12V22" stroke="currentColor" stroke-width="2"/><path d="M12 12L21 7" stroke="currentColor" stroke-width="2"/><path d="M12 12L3 7" stroke="currentColor" stroke-width="2"/></svg>`,
		title: 'Local-First',
		description: 'All data stored in your browser via IndexedDB. No account, no server, no internet required.',
		color: 'var(--color-lavender)',
		bgColor: 'var(--color-lavender-pale)',
	},
	{
		icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14H12L11 22L21 10H12L13 2Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>`,
		title: '60fps Rendering',
		description: 'GPU-accelerated canvas. Smooth painting even on large maps.',
		color: 'var(--color-amber)',
		bgColor: 'var(--color-amber-light)',
	},
	{
		icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M3 10H7L10 3L14 17L17 10H21" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
		title: 'Smart Undo/Redo',
		description: 'Lightweight JSON patches instead of full snapshots. Up to 50 steps, persisted across sessions.',
		color: 'var(--color-mint)',
		bgColor: 'var(--color-mint-light)',
	},
	{
		icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M21 8V16C21 18.2 19.2 20 17 20H7C4.8 20 3 18.2 3 16V8C3 5.8 4.8 4 7 4H17C19.2 4 21 5.8 21 8Z" stroke="currentColor" stroke-width="2"/><path d="M12 9V15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M9 12H15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
		title: 'Tiny Exports',
		description: 'MsgPack + zlib compression for compact .2dp project files you can share anywhere.',
		color: 'var(--color-rose)',
		bgColor: 'var(--color-rose-light)',
	},
];
---

<section class="py-20 px-5 min-[700px]:py-25 min-[700px]:px-6 bg-bg-alt relative before:content-[''] before:absolute before:-top-px before:inset-x-0 before:h-15 before:bg-bg before:rounded-[0_0_50%_50%]" id="tech">
	<div class="max-w-300 mx-auto">
		<div class="text-center mb-16 reveal">
			<span class="font-display text-[13px] font-semibold uppercase tracking-[0.14em] text-lavender mb-3 block">Built Different</span>
			<h2 class="text-[clamp(28px,5vw,44px)] font-bold text-foreground mb-4">Engineered for performance</h2>
			<p class="text-lg text-muted max-w-140 leading-[1.7] mx-auto">
				No bloated Electron app. Just a fast, lightweight editor that runs entirely in your browser.
			</p>
		</div>

		<div class="grid grid-cols-1 min-[700px]:grid-cols-2 gap-5">
			{highlights.map((h, i) => (
				<div class={`bg-surface rounded-lg p-6 min-[700px]:py-7 min-[700px]:px-8 border border-border flex items-start gap-5 transition-[transform,box-shadow] duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-[3px] hover:shadow-hover reveal reveal-delay-${i + 1}`}>
					<div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0" style={`background: ${h.bgColor}; color: ${h.color};`}>
						<Fragment set:html={h.icon} />
					</div>
					<div>
						<h3 class="text-[17px] font-bold mb-1 tracking-[-0.01em]">{h.title}</h3>
						<p class="text-sm text-muted leading-[1.6]">{h.description}</p>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
