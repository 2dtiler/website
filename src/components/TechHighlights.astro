---
const metrics = [
	{ label: 'Storage model', detail: 'IndexedDB session store with no account dependency.', value: 'LOCAL', tone: 'tone-success' },
	{ label: 'Render target', detail: 'GPU-backed canvas pass sized for real map editing.', value: '60 FPS', tone: '' },
	{ label: 'Undo strategy', detail: 'Patch-based history rather than full-scene snapshots.', value: '50 STEPS', tone: '' },
	{ label: 'Export weight', detail: 'Compressed project files designed for transport and handoff.', value: 'SMALL', tone: 'tone-warning' },
];
---

<section class="section" id="tech">
	<div class="site-shell metrics-grid">
		<div class="surface-card feature-card reveal">
			<p class="eyebrow">Performance readout / browser runtime</p>
			<h2 class="section-title">A lightweight web runtime can still feel like a proper editor when the data path is honest.</h2>
			<p class="section-copy compact-copy">
				No Electron shell, no sync-first bottleneck, and no ornamental chrome. The product surface shows exactly where speed and reliability come from.
			</p>
			<div class="stat-row">
				<span class="meta-label">Primary metric</span>
				<div class="segmented-bar" aria-hidden="true">
					{Array.from({ length: 10 }, (_, index) => (
						<span class:list={["segment", { "is-filled": index < 9, "is-accent": index === 9 }]}></span>
					))}
				</div>
				<span class="stat-value">60 FPS</span>
			</div>
		</div>
		<div class="metric-card reveal reveal-delay-1">
			<p class="eyebrow">System notes</p>
			{metrics.map((metric) => (
				<div class="stat-row">
					<span class="meta-label">{metric.label}</span>
					<span class="muted-note">{metric.detail}</span>
					<span class:list={["metric-value", metric.tone]}>{metric.value}</span>
				</div>
			))}
		</div>
	</div>
</section>
