---
const proofCards = [
	{ label: 'No account wall', value: 'LOCAL', detail: 'Projects live in browser storage, so you can open the editor and start immediately.' },
	{ label: 'Safety net', value: '1 MIN', detail: 'Autosave runs on a one-minute cycle so local work keeps getting captured while you build.' },
	{ label: 'Hand-off formats', value: '.2DP / .2DM / .2DT', detail: 'Export a whole project, a single map, or a single tileset depending on what the next step needs.' },
	{ label: 'Art outputs', value: 'PNG / GIF / SHEET', detail: 'The image editor can also export stills, animations, and sprite sheets for supporting art workflows.' },
];
---

<section class="section" id="proof">
	<div class="site-shell grid gap-6 xl:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] xl:items-start">
		<div class="feature-card reveal">
			<p class="eyebrow">Trust layer / why this feels easier to stick with</p>
			<h2 class="section-title">Free forever, open source, and designed to remove the usual friction.</h2>
			<p class="section-copy compact-copy">
				This is not a bait-and-switch tool. You can open it in the browser, build locally, save as you go, and keep your project flow simple instead of being pushed through accounts, installs, or upgrade pressure.
			</p>
			<div
				role="img"
				aria-label="Placeholder for export panel, sprite sheet preview, and project handoff screenshot"
				class="hero-viewport grid min-h-72 content-between border-dashed p-4"
			>
				<p class="eyebrow">Image slot / trust proof</p>
				<p class="card-copy">Placeholder / export panel, sprite sheet preview, and project handoff screenshot</p>
			</div>
		</div>

		<div class="grid gap-4 md:grid-cols-2">
			{proofCards.map((card, index) => (
				<article class={`feature-card reveal reveal-delay-${(index % 4) + 1}`}>
					<p class="eyebrow">{card.label}</p>
					<p class="meta-value mt-1 text-2xl uppercase sm:text-3xl">{card.value}</p>
					<p class="card-copy">{card.detail}</p>
				</article>
			))}
		</div>
	</div>
</section>
