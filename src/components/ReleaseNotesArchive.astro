---
import ReleaseNoteCard from './ReleaseNoteCard.astro';
import type { ReleaseNote } from '../data/releaseNotes';

interface Props {
	notes: ReleaseNote[];
	currentPage: number;
	totalPages: number;
}

const { notes, currentPage, totalPages } = Astro.props;

const pageHref = (page: number) => (page === 1 ? '/blog' : `/blog/page/${page}`);
const previousHref = currentPage > 1 ? pageHref(currentPage - 1) : undefined;
const nextHref = currentPage < totalPages ? pageHref(currentPage + 1) : undefined;

function getPaginationItems() {
	if (totalPages <= 7) {
		return Array.from({ length: totalPages }, (_, index) => index + 1);
	}

	const items: Array<number | 'ellipsis-start' | 'ellipsis-end'> = [1];
	const windowStart = Math.max(2, currentPage - 1);
	const windowEnd = Math.min(totalPages - 1, currentPage + 1);

	if (windowStart > 2) {
		items.push('ellipsis-start');
	}

	for (let page = windowStart; page <= windowEnd; page += 1) {
		items.push(page);
	}

	if (windowEnd < totalPages - 1) {
		items.push('ellipsis-end');
	}

	items.push(totalPages);

	return items;
}

const paginationItems = getPaginationItems();
---

<section class="mx-auto w-full max-w-7xl px-6 py-20 lg:px-8">
	<header class="reveal grid gap-8 lg:grid-cols-[minmax(0,1.1fr)_320px] lg:items-end">
		<div class="flex flex-col gap-4">
			<p class="font-label-mono text-xs uppercase tracking-[0.28em] text-secondary">Release notes / shipping log</p>
			<h1 class="max-w-4xl text-4xl font-semibold uppercase tracking-[-0.04em] text-primary md:text-6xl">Product changes, editor improvements, and workflow updates.</h1>
			<p class="max-w-3xl text-lg leading-8 text-on-surface-variant">
				This archive is generated from published GitHub releases for 2D Tiler and published as static Astro pages with versioned detail routes and paginated archive pages.
			</p>
		</div>
		<div class="reveal reveal-delay-1 flex flex-col gap-4 rounded-xl border border-outline/35 bg-surface-container-low/70 p-6 backdrop-blur-2xl">
			<div class="flex items-center justify-between gap-4 border-b border-outline/20 pb-4">
				<div>
					<p class="font-label-mono text-[11px] uppercase tracking-[0.22em] text-on-surface-variant">Archive page</p>
					<p class="mt-1 text-sm text-primary">Paginated release notes</p>
				</div>
				<span class="font-display-dot text-4xl text-primary">{String(currentPage).padStart(2, '0')}</span>
			</div>
			<div class="flex items-center justify-between gap-4">
				<div>
					<p class="font-label-mono text-[11px] uppercase tracking-[0.22em] text-on-surface-variant">Total pages</p>
					<p class="mt-1 text-sm text-primary">Static Astro routes</p>
				</div>
				<span class="font-display-dot text-4xl text-primary">{String(totalPages).padStart(2, '0')}</span>
			</div>
		</div>
	</header>

	<div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
		{notes.map((note, index) => <ReleaseNoteCard note={note} index={index} />)}
	</div>

	<div class="mt-10 flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
		<div class="flex flex-wrap gap-3">
			{previousHref && (
				<a class="inline-flex items-center justify-center border border-outline px-4 py-2 font-body text-xs font-medium uppercase tracking-[0.24em] text-primary transition-colors duration-200 hover:bg-primary hover:text-surface" href={previousHref}>
					Previous
				</a>
			)}
			{nextHref && (
				<a class="inline-flex items-center justify-center border border-outline px-4 py-2 font-body text-xs font-medium uppercase tracking-[0.24em] text-primary transition-colors duration-200 hover:bg-primary hover:text-surface" href={nextHref}>
					Next
				</a>
			)}
		</div>
		<ul class="flex flex-wrap items-center gap-2" aria-label="Release note pages">
			{paginationItems.map((item) => (
				<li>
					{typeof item === 'number' ? (
						item === currentPage ? (
							<span class="inline-flex min-w-10 items-center justify-center border border-secondary/40 bg-secondary/10 px-3 py-2 font-label-mono text-xs uppercase tracking-[0.2em] text-secondary" aria-current="page">{item}</span>
						) : (
							<a class="inline-flex min-w-10 items-center justify-center border border-outline/30 px-3 py-2 font-label-mono text-xs uppercase tracking-[0.2em] text-on-surface-variant transition-colors duration-200 hover:border-outline hover:text-primary" href={pageHref(item)}>{item}</a>
						)
					) : (
						<span class="inline-flex min-w-10 items-center justify-center px-3 py-2 font-label-mono text-xs uppercase tracking-[0.2em] text-on-surface-variant" aria-hidden="true">...</span>
					)}
				</li>
			))}
		</ul>
	</div>
</section>
