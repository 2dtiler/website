---
const steps = [
	{
		number: '01',
		title: 'Import your tileset',
		description: 'Upload any image as a tileset. Configure tile size, organize into groups, and start selecting tiles to paint with.',
		accent: 'var(--color-lavender)',
		accentBg: 'var(--color-lavender-pale)',
	},
	{
		number: '02',
		title: 'Paint your map',
		description: 'Use brushes, bucket fill, or terrain fill to paint tiles onto layers. Add objects, images, and create complex multi-layered scenes.',
		accent: 'var(--color-peach)',
		accentBg: 'var(--color-peach-light)',
	},
	{
		number: '03',
		title: 'Export & use',
		description: 'Export your project, individual maps, or tilesets as compact binary files. Use them directly in your game engine of choice.',
		accent: 'var(--color-mint)',
		accentBg: 'var(--color-mint-light)',
	},
];
---

<section class="py-25 px-6 bg-bg" id="workflow">
	<div class="max-w-300 mx-auto">
		<div class="text-center mb-18 reveal">
			<span class="font-display text-[13px] font-semibold uppercase tracking-[0.14em] text-lavender mb-3 block">Workflow</span>
			<h2 class="text-[clamp(28px,5vw,44px)] font-bold text-foreground mb-4">Simple workflow, powerful results</h2>
			<p class="text-lg text-muted max-w-140 leading-[1.7] mx-auto">
				Get from tileset to finished map in three easy steps.
			</p>
		</div>

		<div class="flex flex-col items-center gap-10 md:flex-row md:gap-6 md:justify-center md:items-start">
			{steps.map((step, i) => (
				<div class={`flex-1 max-w-100 md:max-w-[320px] text-center relative reveal reveal-delay-${i + 1}`}>
					<div
						class="inline-flex items-center justify-center w-14 h-14 rounded-md font-display text-xl font-extrabold mb-5"
						style={`background: ${step.accentBg}; color: ${step.accent};`}
					>
						{step.number}
					</div>
					<h3 class="text-xl font-bold mb-2.5 tracking-[-0.01em]">{step.title}</h3>
					<p class="text-[15px] text-muted leading-[1.65]">{step.description}</p>
					{i < steps.length - 1 && (
						<div class="hidden md:block absolute top-7 -right-8" aria-hidden="true">
							<svg width="40" height="12" viewBox="0 0 40 12" fill="none">
								<path d="M0 6H32M32 6L26 1M32 6L26 11" stroke="var(--color-border)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
						</div>
					)}
				</div>
			))}
		</div>
	</div>
</section>
