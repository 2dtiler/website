---
const steps = [
	{
		number: '01',
		title: 'Bring in art and get it into a usable grid fast.',
		description: 'Import tileset images, choose a tile size, and group related assets before you paint a single room or route.',
		proof: ['Tilesets from 8px to 128px', 'Organize maps and tilesets into groups'],
		placeholder: 'Placeholder / tileset import and setup screenshot',
	},
	{
		number: '02',
		title: 'Build the map, stack layers, and place gameplay information in one pass.',
		description: 'Paint with fast brushes, fill terrain, reorder layers, and add points, shapes, and metadata without leaving the editor.',
		proof: ['Tile, image, object, and group layers', 'Objects for triggers, zones, and markers'],
		placeholder: 'Placeholder / map canvas with layers and objects screenshot',
	},
	{
		number: '03',
		title: 'Export the exact asset bundle you need and keep moving.',
		description: 'Save compact project files, export individual maps or tilesets, and support sprite work with PNG, GIF, and sprite sheet outputs.',
		proof: ['.2dp / .2dm / .2dt exports', 'PNG / GIF / sprite sheet outputs'],
		placeholder: 'Placeholder / export panel and output files screenshot',
	},
];
---

<section class="section" id="workflow">
	<div class="site-shell">
		<div class="section-header section-header--wide reveal">
			<p class="eyebrow">Workflow / three clear steps</p>
			<h2 class="section-title">Simple enough to start tonight. Structured enough to keep using next month.</h2>
			<p class="section-copy max-w-[56ch]">The page should not make this look harder than it is. 2D Tiler follows a clean loop: bring in art, build the scene, export what you need.</p>
		</div>

		<ol class="mt-10 grid gap-5 lg:grid-cols-3">
			{steps.map((step, index) => (
				<li class={`feature-card reveal reveal-delay-${index + 1}`}>
					<div
						role="img"
						aria-label={step.placeholder}
						class="hero-viewport grid min-h-64 content-between border-dashed p-4"
					>
						<div class="flex items-center justify-between gap-3">
							<p class="eyebrow">Screenshot slot</p>
							<span class="meta-label">{step.number}</span>
						</div>
						<p class="card-copy">{step.placeholder}</p>
					</div>

					<p class="eyebrow mt-5">Step {step.number}</p>
					<h3 class="card-title mt-1 max-w-none">{step.title}</h3>
					<p class="card-copy">{step.description}</p>
					<ul class="mt-5 flex flex-wrap gap-2" aria-label={`Step ${step.number} proof points`}>
						{step.proof.map((item) => (
							<li class="meta-label rounded-full border px-3 py-1.5">
								{item}
							</li>
						))}
					</ul>
				</li>
			))}
		</ol>
	</div>
</section>
