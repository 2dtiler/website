---
const pathname = Astro.url.pathname;
const isHome = pathname === '/';
const isDocs = pathname === '/docs' || pathname === '/docs/' || pathname.startsWith('/docs/');
const isBlog = pathname === '/blog' || pathname.startsWith('/blog/');
---

<header class="sticky top-0 z-50 border-b border-outline/30 bg-surface/85 backdrop-blur-2xl">
	<div class="mx-auto flex w-full max-w-7xl flex-col gap-4 px-6 py-4 lg:flex-row lg:items-center lg:justify-between lg:px-8">
		<div class="flex items-center justify-between gap-6">
			<a href="/" aria-label="2D Tiler home" class="font-body text-2xl font-bold tracking-[-0.08em] text-primary">
				2DTILER
			</a>
			<nav class="flex flex-wrap items-center gap-4 md:gap-6 lg:ml-8" aria-label="Primary">
				<a
					href="/"
					aria-current={isHome ? 'page' : undefined}
					class:list={[
						'border-b pb-1 font-body text-xs font-medium uppercase tracking-[0.24em] transition-colors duration-200',
						isHome ? 'border-primary text-primary' : 'border-transparent text-on-surface-variant hover:text-secondary',
					]}
				>
					Home
				</a>
				<a
					href="/docs"
					aria-current={isDocs ? 'page' : undefined}
					class:list={[
						'border-b pb-1 font-body text-xs font-medium uppercase tracking-[0.24em] transition-colors duration-200',
						isDocs ? 'border-primary text-primary' : 'border-transparent text-on-surface-variant hover:text-secondary',
					]}
				>
					Docs
				</a>
				<a
					href="/blog"
					aria-current={isBlog ? 'page' : undefined}
					class:list={[
						'border-b pb-1 font-body text-xs font-medium uppercase tracking-[0.24em] transition-colors duration-200',
						isBlog ? 'border-primary text-primary' : 'border-transparent text-on-surface-variant hover:text-secondary',
					]}
				>
					Release Notes
				</a>
			</nav>
		</div>

		<div class="flex items-center justify-end">
			<a
				class="inline-flex items-center justify-center border border-outline px-4 py-2 font-body text-xs font-medium uppercase tracking-[0.24em] text-primary transition-colors duration-200 hover:bg-primary hover:text-surface"
				href="https://app.2dtiler.com/"
			>
				Open Editor
			</a>
		</div>
	</div>
</header>
