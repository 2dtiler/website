		<button class="flex flex-col gap-[5px] bg-transparent border-none cursor-pointer p-1 md:hidden" id="nav-toggle" aria-label="Toggle menu">
			<span class="block w-[22px] h-0.5 bg-foreground rounded-[1px] transition-[transform,opacity] duration-300"></span>
			<span class="block w-[22px] h-0.5 bg-foreground rounded-[1px] transition-[transform,opacity] duration-300"></span>
			<span class="block w-[22px] h-0.5 bg-foreground rounded-[1px] transition-[transform,opacity] duration-300"></span>
		</button>
	</div>
</nav>

<script>
	const nav = document.getElementById('nav');
	window.addEventListener('scroll', () => {
		if (window.scrollY > 20) {
			nav?.setAttribute('data-scrolled', '');
		} else {
			nav?.removeAttribute('data-scrolled');
		}
	}, { passive: true });

	const toggle = document.getElementById('nav-toggle');
	const links = document.getElementById('nav-links');
	toggle?.addEventListener('click', () => {
		if (links?.hasAttribute('data-open')) {
			links.removeAttribute('data-open');
		} else {
			links?.setAttribute('data-open', '');
		}
	});
</script>
