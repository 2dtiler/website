			<a href="#features" class="text-base md:text-sm font-display font-medium text-muted transition-colors duration-200 relative after:content-[''] after:absolute after:-bottom-1 after:inset-x-0 after:h-0.5 after:bg-lavender after:rounded-[1px] after:scale-x-0 after:transition-transform after:duration-[250ms] after:ease-[cubic-bezier(0.16,1,0.3,1)] hover:text-foreground hover:after:scale-x-100">Features</a>
			<a href="#workflow" class="text-base md:text-sm font-display font-medium text-muted transition-colors duration-200 relative after:content-[''] after:absolute after:-bottom-1 after:inset-x-0 after:h-0.5 after:bg-lavender after:rounded-[1px] after:scale-x-0 after:transition-transform after:duration-[250ms] after:ease-[cubic-bezier(0.16,1,0.3,1)] hover:text-foreground hover:after:scale-x-100">How It Works</a>
