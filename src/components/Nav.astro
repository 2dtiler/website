			<a href="#shortcuts" class="text-base md:text-sm font-display font-medium text-muted transition-colors duration-200 relative after:content-[''] after:absolute after:-bottom-1 after:inset-x-0 after:h-0.5 after:bg-lavender after:rounded-[1px] after:scale-x-0 after:transition-transform after:duration-[250ms] after:ease-[cubic-bezier(0.16,1,0.3,1)] hover:text-foreground hover:after:scale-x-100">Shortcuts</a>
		</div>

		<a href="https://app.2dtiler.com/" class="hidden md:inline-flex items-center gap-1.5 font-display text-sm font-semibold text-white bg-lavender py-2 px-5 rounded-full transition-all duration-200 hover:bg-[#9578D0] hover:-translate-y-px hover:shadow-[0_4px_16px_rgba(167,139,218,0.35)]">
