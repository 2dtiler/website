---
const heroStats = [
	{ label: 'Session start', value: '[READY]', note: 'No account / no sync wall' },
	{ label: 'Canvas throughput', value: '60 FPS', note: 'GPU-backed drawing' },
	{ label: 'Persistence', value: 'LOCAL', note: 'IndexedDB project storage' },
];
---

<section class="section">
	<div class="site-shell hero-grid">
		<div class="hero-copy">
			<div class="hero-intro">
				<div class="signal-pill reveal">
					<span class="signal-dot" aria-hidden="true"></span>
					<span>Light-mode art direction / dark mode included</span>
				</div>
				<p class="eyebrow reveal reveal-delay-1">Browser-native tile workflow / shipping build</p>
				<h1 class="display-text reveal reveal-delay-1">2D maps stay fast when the editor stays local.</h1>
				<p class="section-copy hero-lede reveal reveal-delay-2">
					Paint tiles, reorder layers, place objects, and export compact project files without a login wall, desktop wrapper, or server round-trip.
				</p>
			</div>
			<div class="button-row hero-actions reveal reveal-delay-3">
				<a class="button button-primary" href="https://app.2dtiler.com/">Open Editor</a>
				<a class="button button-secondary" href="#features">Inspect Features</a>
			</div>
			<div class="hero-metadata reveal reveal-delay-4">
				<div class="hero-meta-row">
					<span class="meta-label">Input</span>
					<span class="muted-note">Tilesets, layers, object data</span>
					<span class="meta-value">01</span>
				</div>
				<div class="hero-meta-row">
					<span class="meta-label">Output</span>
					<span class="muted-note">Compact project and map exports</span>
					<span class="meta-value">02</span>
				</div>
			</div>
		</div>

		<div class="hero-panel surface-card reveal reveal-delay-4">
			<div class="section-stack hero-panel-copy">
				<p class="eyebrow">Live panel / current build</p>
				{heroStats.map((stat) => (
					<div class="hero-meta-row">
						<span class="meta-label">{stat.label}</span>
						<span class="muted-note">{stat.note}</span>
						<span class="meta-value">{stat.value}</span>
					</div>
				))}
			</div>
			<div class="hero-viewport">
				<img src="/screenshot.png" alt="2D Tiler editor canvas and panels" />
			</div>
		</div>
	</div>
</section>
