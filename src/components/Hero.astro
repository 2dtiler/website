---
---

<section class="relative pt-26 px-5 pb-15 md:pt-31 md:px-6 md:pb-20 min-h-screen flex items-center overflow-hidden">
	<!-- Gradient orbs -->
	<div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
		<div class="absolute rounded-full blur-[100px] w-150 h-150 bg-lavender-light opacity-35 -top-[10%] -right-[5%] animate-[float-1_18s_ease-in-out_infinite]"></div>
		<div class="absolute rounded-full blur-[100px] w-125 h-125 bg-peach-light opacity-30 -bottom-[10%] -left-[5%] animate-[float-2_22s_ease-in-out_infinite]"></div>
		<div class="absolute rounded-full blur-[100px] w-[400px] h-[400px] bg-mint-light opacity-25 top-[40%] left-[40%] animate-[float-3_20s_ease-in-out_infinite]"></div>
	</div>

	<!-- Subtle tile grid decoration -->
	<div
		class="absolute inset-0 opacity-[0.04] pointer-events-none bg-[linear-gradient(var(--color-lavender)_1px,transparent_1px),linear-gradient(90deg,var(--color-lavender)_1px,transparent_1px)] bg-[length:48px_48px] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_40%,black_0%,transparent_70%)] [-webkit-mask-image:radial-gradient(ellipse_60%_60%_at_50%_40%,black_0%,transparent_70%)]"
		aria-hidden="true"
	></div>

	<div class="max-w-300 mx-auto w-full flex flex-col items-center text-center gap-14 relative z-1">
		<div class="max-w-180">
			<div class="inline-flex items-center gap-2 font-display text-[13px] font-semibold text-lavender bg-lavender-pale px-4 py-1.5 rounded-full mb-6 tracking-[0.02em] reveal">
				<span class="w-1.5 h-1.5 rounded-full bg-lavender animate-[pulse-dot_2s_ease-in-out_infinite]"></span>
				Free &amp; Local-First
			</div>

			<h1 class="text-[clamp(36px,6.5vw,64px)] font-extrabold leading-[1.1] tracking-[-0.03em] mb-5 reveal reveal-delay-1">
				Build beautiful tile maps
				<span class="bg-[linear-gradient(135deg,var(--color-lavender)_0%,var(--color-peach)_50%,var(--color-rose)_100%)] bg-clip-text text-transparent">in your browser.</span>
			</h1>

			<p class="text-[clamp(16px,2.5vw,19px)] text-muted leading-[1.7] mx-auto mb-8 max-w-140 reveal reveal-delay-2">
				A powerful tile map editor. Paint with brushes,
				manage layers, place objects, and export your work — no account needed.
			</p>

			<div class="flex gap-3.5 justify-center flex-wrap reveal reveal-delay-3">
				<a href="https://app.2dtiler.com/" class="inline-flex items-center gap-2 font-display font-semibold text-[15px] md:text-base py-3 px-6 md:py-3.5 md:px-7 rounded-full transition-all duration-200 ease-out text-white bg-lavender shadow-[0_4px_20px_rgba(167,139,218,0.3)] hover:bg-[#9578D0] hover:-translate-y-0.5 hover:shadow-[0_8px_32px_rgba(167,139,218,0.4)]">
					Open Editor
					<svg width="18" height="18" viewBox="0 0 18 18" fill="none">
						<path d="M7 4L13 9L7 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</a>
				<a href="#features" class="inline-flex items-center gap-2 font-display font-semibold text-[15px] md:text-base py-3 px-6 md:py-3.5 md:px-7 rounded-full transition-all duration-200 ease-out text-muted bg-transparent border-[1.5px] border-border hover:text-foreground hover:border-lavender-light hover:bg-[rgba(167,139,218,0.06)]">
					Explore Features
					<svg width="18" height="18" viewBox="0 0 18 18" fill="none">
						<path d="M9 4V14M9 14L5 10M9 14L13 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
					</svg>
				</a>
			</div>
		</div>

		<div class="w-full max-w-225 reveal reveal-delay-4">
			<div class="bg-surface rounded-lg border border-border shadow-lg overflow-hidden">
				<div class="flex items-center py-3 px-4 bg-[linear-gradient(180deg,#F8F4FC_0%,#F3EEF8_100%)] border-b border-border">
					<div class="flex gap-[7px]">
						<span class="w-2.75 h-2.75 rounded-full bg-rose"></span>
						<span class="w-2.75 h-2.75 rounded-full bg-amber"></span>
						<span class="w-2.75 h-2.75 rounded-full bg-mint"></span>
					</div>
					<span class="font-display text-xs font-semibold text-subtle ml-4 tracking-[0.06em]">2D Tiler</span>
					<span class="flex-1"></span>
				</div>
				<div class=" bg-[#FDFBF9]">
					<img src="screenshot.png" class="w-full" alt="2D Tiler app screenshot" />
				</div>
			</div>
		</div>
	</div>
</section>
