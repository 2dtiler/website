---
const features = [
	{
		label: 'Brush engine',
		title: 'Paint, fill, and vary tiles without leaving the canvas.',
		description: 'Brush sizes run from 1x1 to 5x5, with bucket fill and weighted terrain fill for faster large-area drafting.',
		value: '05 MODES',
		filled: 8,
	},
	{
		label: 'Layer stack',
		title: 'Treat maps like structured scenes instead of flat sheets.',
		description: 'Tile, image, object, and grouped layers can be renamed, hidden, locked, reordered, and nested in a single panel.',
		value: '∞ ORDER',
		filled: 7,
	},
	{
		label: 'Objects',
		title: 'Drop gameplay shapes and typed properties into the same project file.',
		description: 'Use points, rectangles, ellipses, and polygons for triggers, spawn markers, collision zones, and authored metadata.',
		value: 'TYPED',
		filled: 6,
	},
	{
		label: 'Tilesets',
		title: 'Import arbitrary source images and organize them before painting.',
		description: 'Handle tile sizes from 8px through 128px, regroup assets, and keep the browser-side workflow consistent across projects.',
		value: '8-128 PX',
		filled: 9,
	},
	{
		label: 'Search tools',
		title: 'Swap tile patterns across whole maps without manual cleanup.',
		description: 'Pattern-aware find and replace supports wildcards and 5x5 search windows across multiple layers.',
		value: '5X5 GRID',
		filled: 5,
	},
	{
		label: 'Project scope',
		title: 'Keep multiple maps, exports, and undo history in one place.',
		description: 'Projects can manage multiple maps and groups while keeping compact exports and persistent undo/redo history available.',
		value: '50 STEPS',
		filled: 10,
	},
];
---

<section class="section" id="features">
	<div class="site-shell kicker-grid">
		<div class="section-header reveal">
			<p class="eyebrow">Feature matrix / operator view</p>
			<h2 class="section-title">Everything critical is visible, sortable, and one move away from the canvas.</h2>
			<p class="section-copy">
				The editor stays dense without collapsing into noise: large primary actions, tighter support panels, and small monospace metadata pushed to the edge.
			</p>
		</div>
		<div class="feature-grid">
			{features.map((feature, index) => (
				<div class={`feature-card reveal reveal-delay-${(index % 4) + 1}`}>
					<p class="eyebrow">{feature.label}</p>
					<h3 class="card-title">{feature.title}</h3>
					<p class="card-copy">{feature.description}</p>
					<div class="stat-row">
						<span class="meta-label">Capacity</span>
						<div class="segmented-bar" aria-hidden="true">
							{Array.from({ length: 10 }, (_, segmentIndex) => (
								<span class:list={["segment", { "is-filled": segmentIndex < feature.filled }]}></span>
							))}
						</div>
						<span class="stat-value">{feature.value}</span>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
