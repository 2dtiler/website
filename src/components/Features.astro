---
const features = [
	{
		icon: 'grid_view',
		iconColor: 'text-secondary',
		title: 'Tilesets',
		description: 'Manage, slice, and import your pixel art assets with absolute precision.',
	},
	{
		icon: 'layers',
		iconColor: 'text-primary',
		title: 'Layers',
		description: 'Infinite depth. Multi-layered map support with advanced blending modes.',
	},
	{
		icon: 'architecture',
		iconColor: 'text-primary',
		title: 'Collision',
		description: 'Draw collision boundaries directly on the grid and export metadata.',
	},
	{
		icon: 'output',
		iconColor: 'text-primary',
		title: 'Exports',
		description: 'One-click JSON/XML export ready for Unity, Godot, and custom engines.',
	},
];
---

<section class="mx-auto w-full max-w-7xl px-6 py-16 lg:px-8" id="features">
	<div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
		{features.map((feature, index) => (
			<article class={`reveal reveal-delay-${(index % 4) + 1} flex flex-col gap-4 rounded-xl border border-outline/35 bg-surface-container-low/70 p-8 backdrop-blur-2xl`}>
				<span class:list={['material-symbols-outlined text-[32px]', feature.iconColor]}>{feature.icon}</span>
				<h2 class="text-2xl font-medium tracking-[-0.03em] text-primary">{feature.title}</h2>
				<p class="text-base leading-7 text-on-surface-variant">{feature.description}</p>
			</article>
		))}
	</div>
</section>
