---
const features = [
	{
		icon: 'grid_view',
		iconColor: 'text-secondary',
		title: 'Map Editor',
		description: 'Paint, erase, fill, select, and autotile layered 2D maps with brush sizes built for fast iteration.',
	},
	{
		icon: 'auto_awesome',
		iconColor: 'text-primary',
		title: 'Terrain Tools',
		description: 'Configure autotile terrain rules and use weighted terrain fill to avoid repetitive tile placement.',
	},
	{
		icon: 'layers',
		iconColor: 'text-primary',
		title: 'Layered Worlds',
		description: 'Keep tile art, image layers, layer groups, and object data organized as maps become more complex.',
	},
	{
		icon: 'image',
		iconColor: 'text-primary',
		title: 'Image Editor',
		description: 'Revise pixel assets with pencil, eraser, fill, line, rectangle, contour, selection, crop, move, and blur tools.',
	},
	{
		icon: 'palette',
		iconColor: 'text-secondary',
		title: 'Palette Workflows',
		description: 'Import common palette formats including GIMP GPL, Adobe ASE, Aseprite, JASC PAL, Paint.NET TXT, and HEX lists.',
	},
	{
		icon: 'smart_toy',
		iconColor: 'text-primary',
		title: 'AI Asset Drafts',
		description: 'Generate starting points for tilesets, sprites, backgrounds, icons, UI elements, and VFX with provider-backed models.',
	},
	{
		icon: 'save',
		iconColor: 'text-primary',
		title: 'Project Files',
		description: 'Work locally in the browser and move full projects, maps, and tilesets through native .2dp, .2dm, and .2dt files.',
	},
	{
		icon: 'output',
		iconColor: 'text-primary',
		title: 'Exports',
		description: 'Move maps and tilesets to Godot, Unity, Tiled, GameMaker, Defold, Phaser, tIDE, Mappy, raster, and native workflows.',
	},
];
---

<section class="mx-auto w-full max-w-7xl px-6 py-16 lg:px-8" id="features">
	<div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
		{features.map((feature, index) => (
			<article class={`reveal reveal-delay-${(index % 4) + 1} flex flex-col gap-4 rounded-xl border border-outline/35 bg-surface-container-low/70 p-8 backdrop-blur-2xl`}>
				<span class:list={['material-symbols-outlined text-[32px]', feature.iconColor]}>{feature.icon}</span>
				<h2 class="text-2xl font-medium text-primary">{feature.title}</h2>
				<p class="text-base leading-7 text-on-surface-variant">{feature.description}</p>
			</article>
		))}
	</div>
</section>
