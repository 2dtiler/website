---
const features = [
	{
		label: 'Map building',
		title: 'Block out maps fast, then keep refining without tool-switching fatigue.',
		description: 'Paint, erase, bucket fill, and use weighted terrain fill directly on the canvas with brush sizes from 1x1 to 5x5.',
		proof: ['1x1 to 5x5 brushes', 'Bucket fill + terrain fill'],
	},
	{
		label: 'Layers',
		title: 'Keep backgrounds, gameplay tiles, props, and references organized in one scene.',
		description: 'Use tile, image, object, and grouped layers that can be renamed, hidden, locked, reordered, and nested.',
		proof: ['Tile + image + object layers', 'Hide / lock / reorder / group'],
	},
	{
		label: 'Tilesets',
		title: 'Bring in your art once and keep it usable across real projects.',
		description: 'Import source images, normalize tile size, and organize tilesets and map groups so projects stay manageable as they grow.',
		proof: ['8px to 128px tiles', 'Grouped maps and grouped tilesets'],
	},
	{
		label: 'Gameplay data',
		title: 'Add triggers, zones, markers, and metadata in the same workspace as your level art.',
		description: 'Place points, rectangles, ellipses, and polygons, then attach typed properties instead of tracking game logic in a separate tool.',
		proof: ['Point / rectangle / ellipse / polygon', 'Typed properties in-project'],
	},
	{
		label: 'Sprite workflow',
		title: 'Handle sprite edits and animation exports without bouncing to another app for every fix.',
		description: 'Use pixel drawing tools, frame timelines, and exports for PNG, GIF, and sprite sheets when you need art support around your maps.',
		proof: ['PNG / GIF / sprite sheet export', 'Frame timeline for animation'],
	},
	{
		label: 'Cleanup + export',
		title: 'Make global map changes and hand off compact files that travel cleanly.',
		description: 'Use pattern-aware find and replace across layers, keep local autosave running, and export projects, maps, or tilesets as compact files.',
		proof: ['5x5 pattern find and replace', 'Project / map / tileset export'],
	},
];
---

<section class="section" id="features">
	<div class="site-shell grid gap-10 xl:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] xl:gap-14">
		<div class="section-header reveal mb-0">
			<p class="eyebrow">Why people switch / less friction, more shipping</p>
			<h2 class="section-title">Stop duct-taping together separate tools just to finish one 2D scene.</h2>
			<p class="section-copy">
				2D Tiler is built for the developer who wants one place to build maps, sort layers, annotate gameplay data, clean up tiles, edit supporting art, and export work that is ready to move.
			</p>
			<div class="feature-card text-sm">
				<p class="eyebrow">What changes when everything is in one app</p>
				<p>You spend less time relearning interfaces, less time moving assets between tabs, and less time cleaning up avoidable mistakes at the end.</p>
			</div>
		</div>

		<div class="grid gap-4 md:grid-cols-2">
			{features.map((feature, index) => (
				<article class={`feature-card reveal reveal-delay-${(index % 4) + 1}`}>
					<p class="eyebrow">{feature.label}</p>
					<h3 class="card-title mt-1 max-w-none">{feature.title}</h3>
					<p class="card-copy">{feature.description}</p>
					<ul class="mt-5 flex flex-wrap gap-2" aria-label={`${feature.label} proof points`}>
						{feature.proof.map((item) => (
							<li class="meta-label rounded-full border px-3 py-1.5">
								{item}
							</li>
						))}
					</ul>
				</article>
			))}
		</div>
	</div>
</section>
