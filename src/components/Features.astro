---
const features = [
	{
		title: 'Tile Painting',
		description: 'Paint tiles with variable brush sizes from 1x1 to 5x5. Use bucket fill for large areas or terrain fill with weighted random tiles.',
		color: 'var(--color-lavender)',
		bgColor: 'var(--color-lavender-pale)',
		icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M16.5 3.5L22 9L10 21H4.5V15.5L16.5 3.5Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 6L20 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
	},
	{
		title: 'Layer System',
		description: 'Tile layers, image layers, object layers, and groups. Reorder, lock, hide, rename, and nest — just like Photoshop.',
		color: 'var(--color-sky)',
		bgColor: 'var(--color-sky-light)',
		icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 3L25 9L14 15L3 9L14 3Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M3 14L14 20L25 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M3 19L14 25L25 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
	},
	{
		title: 'Object Editor',
		description: 'Place rectangles, points, ellipses, and polygons. Add typed custom properties for game entities like spawn points and triggers.',
		color: 'var(--color-peach)',
		bgColor: 'var(--color-peach-light)',
		icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="4" y="4" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="2"/><circle cx="19.5" cy="19.5" r="5" stroke="currentColor" stroke-width="2"/><path d="M15 4.5H24V13.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
	},
	{
		title: 'Tileset Management',
		description: 'Import any image as a tileset. Organize into groups, configure tile sizes from 8px to 128px, zoom, rename, and export.',
		color: 'var(--color-mint)',
		bgColor: 'var(--color-mint-light)',
		icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="3" y="3" width="9" height="9" rx="1" stroke="currentColor" stroke-width="2"/><rect x="16" y="3" width="9" height="9" rx="1" stroke="currentColor" stroke-width="2"/><rect x="3" y="16" width="9" height="9" rx="1" stroke="currentColor" stroke-width="2"/><rect x="16" y="16" width="9" height="9" rx="1" stroke="currentColor" stroke-width="2"/></svg>`,
	},
	{
		title: 'Find & Replace',
		description: 'Pattern-based tile search and replace across multiple layers. Supports grid patterns up to 5×5 with wildcards.',
		color: 'var(--color-rose)',
		bgColor: 'var(--color-rose-light)',
		icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="12" cy="12" r="7" stroke="currentColor" stroke-width="2"/><path d="M17 17L24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M9 12H15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M12 9V15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
	},
	{
		title: 'Project & Maps',
		description: 'Manage multiple maps per project with groups. Export compressed binary files. Full undo/redo with up to 50 steps.',
		color: 'var(--color-amber)',
		bgColor: 'var(--color-amber-light)',
		icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M4 7C4 5.9 4.9 5 6 5H11L13 7H22C23.1 7 24 7.9 24 9V21C24 22.1 23.1 23 22 23H6C4.9 23 4 22.1 4 21V7Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M10 15H18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M10 19H15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
	},
];
---

<section class="py-20 px-5 min-[600px]:px-6 min-[600px]:py-25 bg-bg-alt relative before:content-[''] before:absolute before:-top-px before:inset-x-0 before:h-15 before:bg-bg before:rounded-[0_0_50%_50%]" id="features">
	<div class="max-w-300 mx-auto">
		<div class="text-center mb-16 reveal">
			<span class="font-display text-[13px] font-semibold uppercase tracking-[0.14em] text-lavender mb-3 block">Features</span>
			<h2 class="text-[clamp(28px,5vw,44px)] font-bold text-foreground mb-4">Everything you need to build game worlds</h2>
			<p class="text-lg text-muted max-w-140 leading-[1.7] mx-auto">
				A complete toolkit for 2D tile map creation — from painting individual tiles
				to managing complex multi-layer projects.
			</p>
		</div>

		<div class="grid grid-cols-1 min-[600px]:grid-cols-2 min-[900px]:grid-cols-3 gap-4 min-[600px]:gap-6">
			{features.map((feature, i) => (
				<div class={`bg-surface rounded-lg p-6 min-[600px]:p-8 border border-border transition-[transform,box-shadow] duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] cursor-default hover:-translate-y-1 hover:shadow-hover reveal reveal-delay-${(i % 3) + 1}`}>
					<div class="w-13 h-13 rounded-[14px] flex items-center justify-center mb-5" style={`background: ${feature.bgColor}; color: ${feature.color};`}>
						<Fragment set:html={feature.icon} />
					</div>
					<h3 class="text-lg font-bold mb-2 tracking-[-0.01em]">{feature.title}</h3>
					<p class="text-[15px] text-muted leading-[1.65]">{feature.description}</p>
				</div>
			))}
		</div>
	</div>
</section>
