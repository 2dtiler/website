<section class="section">
	<div class="site-shell">
		<div class="reveal grid gap-8 rounded-2xl border border-(--border-visible) bg-(--surface) p-8 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)] lg:items-end lg:gap-10">
			<div class="grid gap-4">
				<p class="eyebrow">Final call / open the editor</p>
				<h2 class="display-text max-w-[9ch]! text-[clamp(2.8rem,7vw,5.5rem)]!">Make the map. Save the project. Keep moving.</h2>
				<p class="section-copy max-w-[42ch]">
					If you want one simpler place to build 2D maps, tilesets, objects, and supporting sprite work, 2D Tiler is ready right now. No install. No account. No paywall.
				</p>
			</div>

			<div class="grid gap-4 lg:justify-items-end">
				<a class="button button-primary" href="https://app.2dtiler.com/">Open Editor</a>
				<p class="font-(--font-mono) text-[11px] uppercase tracking-[0.12em] text-(--text-secondary)">Free forever / MIT / light + dark mode</p>
			</div>
		</div>
	</div>
</section>