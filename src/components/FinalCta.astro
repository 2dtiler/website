<section class="mx-auto w-full max-w-7xl px-6 py-24 lg:px-8">
	<div class="reveal relative overflow-hidden border border-outline/40 border-l-4 border-l-secondary bg-surface-container-low/40 p-8 md:p-12">
		<div class="absolute right-0 top-0 p-8 opacity-10">
			<span class="material-symbols-outlined text-[120px] text-primary">terminal</span>
		</div>
		<div class="relative z-10 flex max-w-2xl flex-col gap-6">
			<div class="inline-flex w-max border border-secondary/30 px-3 py-1 font-label-mono text-xs uppercase tracking-[0.24em] text-secondary">
				MIT License
			</div>
			<h2 class="text-4xl font-semibold uppercase tracking-[-0.04em] text-primary md:text-5xl">Free. Forever.</h2>
