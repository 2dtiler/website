---
const showcaseCards = [
	{ title: 'Overworlds and routes', note: 'Placeholder / large traversal map screenshot' },
	{ title: 'Interiors and encounter spaces', note: 'Placeholder / room layout screenshot' },
	{ title: 'Collision, triggers, and points of interest', note: 'Placeholder / object layer screenshot' },
	{ title: 'Sprite support and animation passes', note: 'Placeholder / sprite editor close-up screenshot' },
];

const shortcuts = [
	{ key: 'B', label: 'Paint' },
	{ key: 'G', label: 'Fill' },
	{ key: '1-5', label: 'Brush size' },
	{ key: 'CMD+H', label: 'Find + replace' },
	{ key: 'CMD+S', label: 'Save' },
	{ key: 'CMD+Z', label: 'Undo' },
];
---

<section class="section" id="showcase">
	<div class="site-shell grid gap-8">
		<div class="section-header reveal mb-0">
			<p class="eyebrow">Showcase / what this can replace in your workflow</p>
			<h2 class="section-title !max-w-[16ch]">One editor for the map work, data work, and support art that usually gets split apart.</h2>
			<p class="section-copy max-w-[58ch]">
				Use this section to show the product doing different kinds of real game work. The goal is not abstract polish. The goal is helping someone picture their own project inside the editor.
			</p>
		</div>

		<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
			{showcaseCards.map((card, index) => (
				<article class={`reveal reveal-delay-${(index % 4) + 1} rounded-[16px] border border-[var(--border)] bg-[var(--surface)] p-4`}>
					<div
						role="img"
						aria-label={card.note}
						class="grid aspect-[4/5] content-between rounded-[14px] border border-dashed border-[var(--border-visible)] bg-[var(--surface-raised)] p-4"
					>
						<p class="eyebrow">Image slot</p>
						<p class="text-sm leading-6 text-[var(--text-secondary)]">{card.note}</p>
					</div>
					<h3 class="mt-4 text-lg leading-tight text-[var(--text-display)]">{card.title}</h3>
				</article>
			))}
		</div>

		<div class="reveal grid gap-4 rounded-[16px] border border-[var(--border)] bg-[var(--surface)] p-5 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-center">
			<div>
				<p class="eyebrow">Fast path / the work gets quicker as your hands learn it</p>
				<p class="mt-3 max-w-[42ch] text-sm leading-7 text-[var(--text-secondary)]">
					Keyboard shortcuts are still part of the sales story because speed matters. They just work better here as supporting proof than as the whole section.
				</p>
			</div>
			<ul class="flex flex-wrap gap-2" aria-label="Keyboard shortcut highlights">
				{shortcuts.map((shortcut) => (
					<li class="inline-flex items-center gap-2 rounded-full border border-[var(--border-visible)] px-3 py-2">
						<kbd class="font-[var(--font-mono)] text-[11px] uppercase tracking-[0.08em] text-[var(--text-display)]">{shortcut.key}</kbd>
						<span class="text-sm text-[var(--text-secondary)]">{shortcut.label}</span>
					</li>
				))}
			</ul>
		</div>
	</div>
</section>
