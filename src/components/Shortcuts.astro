---
const shortcuts = [
	{ key: 'B', label: 'Paint', color: 'var(--color-lavender)', bgColor: 'var(--color-lavender-pale)' },
	{ key: 'E', label: 'Erase', color: 'var(--color-rose)', bgColor: 'var(--color-rose-light)' },
	{ key: 'G', label: 'Fill', color: 'var(--color-mint)', bgColor: 'var(--color-mint-light)' },
	{ key: 'S', label: 'Select', color: 'var(--color-sky)', bgColor: 'var(--color-sky-light)' },
	{ key: '1-5', label: 'Brush Size', color: 'var(--color-amber)', bgColor: 'var(--color-amber-light)' },
	{ key: '⌘Z', label: 'Undo', color: 'var(--color-peach)', bgColor: 'var(--color-peach-light)' },
	{ key: '⌘S', label: 'Save', color: 'var(--color-mint)', bgColor: 'var(--color-mint-light)' },
	{ key: '⌘H', label: 'Find & Replace', color: 'var(--color-lavender)', bgColor: 'var(--color-lavender-pale)' },
];
---

<section class="py-20 px-5 min-[500px]:py-25 min-[500px]:px-6 bg-bg" id="shortcuts">
	<div class="max-w-300 mx-auto">
		<div class="flex flex-col items-center gap-12 text-center min-[900px]:flex-row min-[900px]:items-center min-[900px]:gap-20 min-[900px]:text-left">
			<div class="flex-1 min-w-70 reveal min-[900px]:block min-[900px]:items-stretch">
				<span class="font-display text-[13px] font-semibold uppercase tracking-[0.14em] text-lavender mb-3 block">Keyboard-First</span>
				<h2 class="text-[clamp(28px,5vw,44px)] font-bold text-foreground mb-4">Master the shortcuts</h2>
				<p class="text-lg text-muted max-w-140 leading-[1.7]">
					Every tool is a keypress away. Speed up your workflow with intuitive
					keyboard shortcuts designed for rapid iteration.
				</p>
			</div>

			<div class="grid grid-cols-2 gap-5 min-[500px]:grid-cols-4 min-[500px]:gap-4 flex-1">
				{shortcuts.map((s, i) => (
					<div class={`flex flex-col items-center gap-2.5 text-center reveal reveal-delay-${(i % 4) + 1}`}>
						<kbd
							class="flex items-center justify-center w-14 h-14 min-[500px]:w-16 min-[500px]:h-16 rounded-[14px] font-display text-base min-[500px]:text-lg font-bold cursor-default select-none transition-[transform,box-shadow] duration-150 ease-out hover:-translate-y-0.5 hover:shadow-[0_4px_0_color-mix(in_srgb,var(--key-color)_15%,transparent),0_8px_20px_rgba(120,100,160,0.1)] active:translate-y-px active:shadow-[0_0px_0_color-mix(in_srgb,var(--key-color)_15%,transparent),0_1px_4px_rgba(120,100,160,0.06)]"
							style={`--key-color: ${s.color}; --key-bg: ${s.bgColor}; color: var(--key-color); background: var(--key-bg); border: 1.5px solid color-mix(in srgb, var(--key-color) 20%, transparent); box-shadow: 0 2px 0 color-mix(in srgb, var(--key-color) 15%, transparent), 0 4px 12px rgba(120, 100, 160, 0.06);`}
						>
							{s.key}
						</kbd>
						<span class="font-display text-xs font-semibold text-muted tracking-[0.02em]">{s.label}</span>
					</div>
				))}
			</div>
		</div>
	</div>
</section>
