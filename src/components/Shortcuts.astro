---
const shortcuts = [
	{ key: 'B', label: 'Paint tile brush' },
	{ key: 'E', label: 'Erase active cells' },
	{ key: 'G', label: 'Bucket fill area' },
	{ key: 'S', label: 'Selection tool' },
	{ key: '1-5', label: 'Brush footprint' },
	{ key: 'CMD+Z', label: 'Undo previous edit' },
	{ key: 'CMD+S', label: 'Persist current project' },
	{ key: 'CMD+H', label: 'Find and replace tiles' },
];
---

<section class="section" id="shortcuts">
	<div class="site-shell kicker-grid">
		<div class="section-header reveal">
			<p class="eyebrow">Keyboard surface / fast path</p>
			<h2 class="section-title">The repetitive work is designed to collapse into muscle memory.</h2>
			<p class="section-copy">
				Shortcut handling is visible, consistent, and mechanical. The interface does not pretend the fastest route is secondary.
			</p>
		</div>
		<div class="shortcut-grid">
			{shortcuts.map((shortcut, index) => (
				<div class={`shortcut-card reveal reveal-delay-${(index % 4) + 1}`}>
					<div class="shortcut-head">
						<span class="eyebrow">Shortcut</span>
						<kbd class="shortcut-key">{shortcut.key}</kbd>
					</div>
					<p class="card-copy">{shortcut.label}</p>
				</div>
			))}
		</div>
	</div>
</section>
