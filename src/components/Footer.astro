---
---

<footer class="px-5 pb-10 min-[600px]:px-6 min-[600px]:pb-12 bg-bg">
	<div class="max-w-300 mx-auto">
		<div class="h-px bg-[linear-gradient(90deg,transparent_0%,var(--color-border)_30%,var(--color-border)_70%,transparent_100%)] mb-12"></div>

		<div class="flex flex-col items-center text-center gap-4">
			<div class="flex items-center gap-2.5">
				<svg width="24" height="24" viewBox="0 0 32 32" fill="none">
					<rect x="2" y="2" width="12" height="12" rx="2.5" fill="#A78BDA"/>
					<rect x="18" y="2" width="12" height="12" rx="2.5" fill="#F2B5A0"/>
					<rect x="2" y="18" width="12" height="12" rx="2.5" fill="#7EC4AA"/>
					<rect x="18" y="18" width="12" height="12" rx="2.5" fill="#E8C470"/>
				</svg>
				<span class="font-display font-bold text-lg text-foreground">2D Tiler</span>
			</div>

			<p class="text-[15px] text-muted">Made for game developers. Free &amp; open source.</p>

			<div class="flex items-center gap-3 mt-1">
				<a href="https://app.2dtiler.com/" class="font-display text-sm font-medium text-muted transition-colors duration-200 hover:text-lavender">Open Editor</a>
				<span class="text-subtle text-xs">&middot;</span>
				<a href="#features" class="font-display text-sm font-medium text-muted transition-colors duration-200 hover:text-lavender">Features</a>
			</div>

			<p class="text-[13px] text-subtle mt-2">&copy; 2026 2D Tiler</p>
		</div>
	</div>
</footer>
